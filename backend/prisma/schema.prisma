// ============================================================
//  Prim'O — schema.prisma
//  User unifié + Company (multi-tenant). Corrige les règles
//  métier violées + dette technique de l'ancienne version.
//  ⚠️ Deux contraintes ne s'expriment pas en Prisma : voir le
//     bloc SQL en bas (CHECK + index partiel) à coller dans une
//     migration vide après `migrate dev`.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────

enum Role {
  ADMIN
  OWNER
  MANAGER
  EMPLOYEE
}

enum CompanyStatus {
  PENDING   // Company créée, en attente de validation ADMIN
  APPROVED  // Company validée par ADMIN, peut créer des users
  REJECTED
}

// Addendum v1.1 §3.5 — 4 catégories officielles de motifs d'attribution.
enum MotifCategory {
  COMPORTEMENTS_INDIVIDUELS
  RELATION_CLIENT
  ESPRIT_COLLECTIF
  ENGAGEMENT
}

// Addendum v1.1 §3.4 — mode de rétribution choisi par l'employeur à chaque allocation.
enum RetributionMode {
  PART_EGALE    // mode 1 : enveloppe ÷ (nbCollaborateurs + 1)
  POURCENTAGE   // mode 2 : % fixe de l'enveloppe
  AUCUNE        // mode 3 : pas de rétribution manager
}

// Cycle de vie d'une enveloppe (addendum v1.1, modèle "Mes enveloppes").
// Valeurs ASCII (contrainte Prisma) ; libellé FR géré à l'affichage.
enum AllocationStatus {
  A_DISTRIBUER  // créée par l'employeur, en attente d'ouverture par le manager
  DISTRIBUEE    // redistribuée et verrouillée (immuable)
}

// ─────────────────────────── ENTREPRISE ──────────────────────
// Remplace `companyName String`. C'est la barrière multi-tenant.

model Company {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  tokenBalance Int       @default(0)   // POOL acheté par l'employeur. CHECK >= 0 en SQL.
  status       CompanyStatus @default(PENDING) // PENDING = en attente de validation ADMIN
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  users        User[]
  inviteCodes  CompanyInviteCode[]
  attributions Attribution[]
  redemptions  Redemption[]
  purchases    CompanyTokenPurchase[]   // historique des recharges du pool (D2)
  allocations  Allocation[]             // enveloppes allouées aux managers (addendum v1.1)
}

// ─────────────────────────── USER UNIQUE ─────────────────────
// Remplace Admin + Manager + Employee. Auth écrite UNE fois.

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String                          // unicité : index partiel en SQL (soft-delete)
  passwordHash    String
  role            Role?                           // null = utilisateur flottant (inscrit, pas encore dans une entreprise)
  firstName       String?                         // null pour ADMIN
  lastName        String?
  profilePhoto    String?                         // clé d'avatar prédéfini (av_1…av_6) ; null = initiales
  balance         Int        @default(0)          // Portefeuille EMPLOYÉ + solde perso MANAGER (rétribution cumulée, addendum v1.1). CHECK >= 0 en SQL.
  isEmailVerified Boolean    @default(false)
  companyId       String?    @db.Uuid             // null = ADMIN OU utilisateur flottant pas encore rattaché
  lastLoginAt     DateTime?                       // RGPD : dernière connexion ; sert au job d'anonymisation des comptes inactifs (3 ans). Null = jamais connecté → repli sur createdAt.
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  company       Company?                 @relation(fields: [companyId], references: [id])
  refreshTokens RefreshToken[]
  emailTokens   EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]

  inviteCodesCreated   CompanyInviteCode[]    @relation("InviteCreatedBy")
  attributionsSent     Attribution[]          @relation("AttribManager")   // en tant que manager
  attributionsReceived Attribution[]          @relation("AttribEmployee")  // en tant qu'employé
  redemptions          Redemption[]
  purchasesCreated     CompanyTokenPurchase[] @relation("PurchaseCreatedBy") // recharges saisies par un admin
  allocationsReceived  Allocation[]           @relation("AllocationManager")   // enveloppes reçues comme manager
  allocationsCreated   Allocation[]           @relation("AllocationCreatedBy") // enveloppes allouées par cet employeur/owner

  @@index([companyId])
  @@index([email])
}

// ─────────────────────────── AUTH TOKENS ─────────────────────
// Plus de 3 FK nullables : un seul userId (rôle déduit de User).

model RefreshToken {
  id           String   @id @default(uuid()) @db.Uuid
  tokenHash    String   @unique
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  replacedById String?  @db.Uuid
  createdAt    DateTime @default(now())

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Stocke le lien de confirmation email (règle 3)
model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Stocke le lien de réinitialisation du mot de passe (usage unique, TTL court).
// Même schéma que la vérification email : token haché, le raw part dans le lien.
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────── CODE D'ENTREPRISE ───────────────
// Modélise VRAIMENT la règle 3 : 24h + plafond + révocable.
// Validité = revokedAt IS NULL AND expiresAt > now AND usedCount < maxUses
// Consommation atomique via $queryRaw (D3) : UPDATE ... WHERE usedCount < maxUses.

model CompanyInviteCode {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  companyId   String    @db.Uuid
  createdById String    @db.Uuid           // le manager qui l'a généré
  expiresAt   DateTime                     // = createdAt + 24h
  maxUses     Int                          // plafond d'usages
  usedCount   Int       @default(0)
  role        Role      @default(EMPLOYEE)  // rôle attribué à l'employé qui s'inscrit

  revokedAt   DateTime?                    // révocation
  createdAt   DateTime  @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User    @relation("InviteCreatedBy", fields: [createdById], references: [id])

  @@index([companyId])
}

// ─────────────────────────── RECHARGE DU POOL (D2) ───────────
// Ledger d'achats : chaque crédit du pool entreprise = une ligne immuable.
// Source de vérité de l'historique ; Company.tokenBalance = solde courant.

model CompanyTokenPurchase {
  id          String   @id @default(uuid()) @db.Uuid
  amount      Int                            // > 0 (Zod + CHECK). Tokens ajoutés au pool.
  note        String?                        // motif/référence d'achat (optionnel)
  companyId   String   @db.Uuid
  createdById String   @db.Uuid              // l'ADMIN qui a crédité
  createdAt   DateTime @default(now())
  stripeSessionId String?  @unique   // id de la session Stripe (cs_...) — garantit l'idempotence


  company   Company @relation(fields: [companyId], references: [id])
  createdBy User    @relation("PurchaseCreatedBy", fields: [createdById], references: [id])

  @@index([companyId])
  @@index([createdById])
}

// ─────────────────────────── LEDGER TOKENS ───────────────────
// Attribution (crédit) + Redemption (débit) = registre append-only.
// INVARIANT : user.balance == SUM(attributionsReceived) - SUM(redemptions)
// Toujours muter le balance DANS la même transaction (voir SOLUTIONS_dette_technique.md).

model Attribution {
  id               String   @id @default(uuid()) @db.Uuid
  amount           Int                            // tokens crédités à l'employé. > 0 (Zod + CHECK)
  motifId          String?  @db.Uuid              // motif officiel (§3.5). Nullable en DB pour les lignes legacy ; REQUIS côté Zod pour toute nouvelle attribution.
  retributionAmount Int     @default(0)           // OBSOLÈTE (addendum v1.1) : la rétribution est désormais portée par Allocation. Figé à 0 pour les nouvelles lignes.
  companyId        String   @db.Uuid              // dénormalisé pour filtre multi-tenant rapide
  managerId        String   @db.Uuid
  employeeId       String   @db.Uuid
  allocationId     String?  @db.Uuid              // enveloppe d'origine (addendum v1.1). Null pour distribution directe OWNER / lignes legacy.
  createdAt        DateTime @default(now())

  company    Company     @relation(fields: [companyId], references: [id])
  manager    User        @relation("AttribManager", fields: [managerId], references: [id])
  employee   User        @relation("AttribEmployee", fields: [employeeId], references: [id])
  motif      Motif?      @relation(fields: [motifId], references: [id])
  allocation Allocation? @relation(fields: [allocationId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([managerId])
  @@index([motifId])
  @@index([allocationId])
}

// ─────────────────────────── MOTIFS D'ATTRIBUTION (§3.5) ──────
// Liste officielle V1, 4 catégories. `tag` = identité stats stable,
// `compliment` = texte affiché au salarié à la réception.
// Gérée par l'ADMIN (motifs personnalisés employeur = V2).
model Motif {
  id         String        @id @default(uuid()) @db.Uuid
  tag        String        @unique          // clé stats stable, ex "PONCTUALITE_PRESENCE"
  label      String                          // libellé interne lisible (ex "Ponctualité & présence")
  category   MotifCategory
  compliment String                          // affiché au salarié au moment de la réception
  active     Boolean       @default(true)
  sortOrder  Int           @default(0)
  createdAt  DateTime      @default(now())

  attributions Attribution[]
}

// ─────────────────────── ALLOCATION ENVELOPPE (§3.2 / §3.4) ───
// L'employeur alloue une enveloppe de tokens à un manager + choisit le mode
// de rétribution. L'enveloppe RESTANTE d'un manager se dérive du registre :
//   restant = SUM(Allocation.amount) − SUM(Attribution.amount + retributionAmount)  [managerId]
model Allocation {
  id          String           @id @default(uuid()) @db.Uuid
  amount      Int                              // taille de l'enveloppe. > 0 (Zod + CHECK)
  mode        RetributionMode
  percentage  Int?                             // mode POURCENTAGE uniquement : 1..100. null sinon (CHECK cohérence).
  status      AllocationStatus @default(A_DISTRIBUER) // cycle de vie de l'enveloppe
  retributionAmount Int        @default(0)     // part R du manager, FIGÉE à l'envoi (0 tant que A_DISTRIBUER)
  distributedAt DateTime?                      // horodatage de l'envoi validé (null tant que A_DISTRIBUER)
  companyId   String           @db.Uuid
  managerId   String           @db.Uuid
  createdById String           @db.Uuid         // employeur/owner qui alloue
  createdAt   DateTime         @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  manager   User    @relation("AllocationManager", fields: [managerId], references: [id])
  createdBy User    @relation("AllocationCreatedBy", fields: [createdById], references: [id])
  attributions Attribution[]                   // distributions issues de cette enveloppe

  @@index([companyId])
  @@index([managerId])
}

// ─────────────────────────── CATÉGORIES (Phase 1 — entité) ──

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique              // "food", "shopping" etc — clé stable pour seed upsert
  label     String
  icon      String                        // IconName string: "coffee", "gift", "ticket", "plane", "heart"
  color     String                        // hex: "#e5784a"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers    PartnerOffer[]
}

// ─────────────────────────── OFFRES PARTENAIRES ──────────────

model PartnerOffer {
  id          String        @id @default(uuid()) @db.Uuid
  partnerName String
  cost        Int                              // prix en tokens
  discountPercent  Int
  categoryId  String        @db.Uuid
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category    Category      @relation(fields: [categoryId], references: [id])
  promoCodes  PromoCode[]
  redemptions Redemption[]

  @@index([categoryId])
  @@index([isActive])
}

model PromoCode {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  isUsed    Boolean   @default(false)         // marqué de façon atomique (règle 5)
  usedAt    DateTime?
  offerId   String    @db.Uuid
  createdAt DateTime  @default(now())

  offer      PartnerOffer @relation(fields: [offerId], references: [id])
  redemption Redemption?

  @@index([offerId])
  @@index([isUsed])
}

model Redemption {
  id          String   @id @default(uuid()) @db.Uuid
  amount      Int                            // snapshot de offer.cost au moment de l'achat
  employeeId  String   @db.Uuid
  offerId     String   @db.Uuid
  promoCodeId String   @unique @db.Uuid      // 1 code = 1 redemption (garanti par DB)
  companyId   String   @db.Uuid
  used        Boolean  @default(false)        // marqué « utilisé » manuellement par l'employé (chez le commerçant)
  createdAt   DateTime @default(now())

  employee  User         @relation(fields: [employeeId], references: [id])
  offer     PartnerOffer @relation(fields: [offerId], references: [id])
  promoCode PromoCode    @relation(fields: [promoCodeId], references: [id])
  company   Company      @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([offerId])
}

// ============================================================
//  MIGRATION SQL À AJOUTER MANUELLEMENT
//  (Prisma ne sait pas exprimer CHECK ni index partiel)
//  → après `migrate dev`, créer une migration vide puis coller :
//
//  -- Règle 1 : soldes jamais négatifs (au niveau DB, pas que le code)
//  ALTER TABLE "User"                 ADD CONSTRAINT user_balance_non_negative   CHECK ("balance" >= 0);
//  ALTER TABLE "Company"              ADD CONSTRAINT company_pool_non_negative    CHECK ("tokenBalance" >= 0);
//  ALTER TABLE "Attribution"          ADD CONSTRAINT attribution_amount_positive  CHECK ("amount" > 0);
//  ALTER TABLE "Redemption"           ADD CONSTRAINT redemption_amount_positive   CHECK ("amount" > 0);
//  ALTER TABLE "CompanyTokenPurchase" ADD CONSTRAINT purchase_amount_positive     CHECK ("amount" > 0);
//
//  -- Email unique SEULEMENT parmi les comptes non supprimés (réinscription après soft-delete)
//  CREATE UNIQUE INDEX user_email_active_unique
//    ON "User" ("email") WHERE "deletedAt" IS NULL;
// ============================================================
