// Prim'O — Prisma Schema
// Base de données : PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Employeur ───────────────────────────────────────────────────────────────

model Employer {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  companyName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  offers    Offer[]
  tokenLogs TokenLog[]

  @@map("employers")
}

// ─── Employé ─────────────────────────────────────────────────────────────────

model Employee {
  id             String   @id @default(uuid())
  email          String   @unique
  phone          String
  firstName      String
  lastName       String
  password       String
  tokenBalance   Int      @default(0)
  isEmailVerified Boolean @default(false)
  isSmsVerified   Boolean @default(false)
  isActive        Boolean @default(false)  // true = double validation OK
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])

  tokenLogs    TokenLog[]
  redemptions  Redemption[]

  @@map("employees")
}

// ─── Attribution de tokens ───────────────────────────────────────────────────

model TokenLog {
  id         String   @id @default(uuid())
  amount     Int      // positif = attribution, négatif = échange
  reason     String   // obligatoire
  createdAt  DateTime @default(now())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])

  @@map("token_logs")
}

// ─── Offres partenaires ──────────────────────────────────────────────────────

model Offer {
  id          String   @id @default(uuid())
  title       String
  description String
  tokenCost   Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])

  promoCodes PromoCode[]

  @@map("offers")
}

// ─── Codes promo ─────────────────────────────────────────────────────────────

model PromoCode {
  id        String   @id @default(uuid())
  code      String   @unique
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id])

  redemption Redemption?

  @@map("promo_codes")
}

// ─── Échanges ────────────────────────────────────────────────────────────────

model Redemption {
  id          String   @id @default(uuid())
  redeemedAt  DateTime @default(now())

  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])

  promoCodeId String    @unique
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])

  @@map("redemptions")
}

// ─── Refresh Tokens ──────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  userType  String   // "employer" | "employee"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}
