generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
}

model Manager {
  id              String    @id @default(uuid()) @db.Uuid
  companyName     String
  email           String    @unique
  passwordHash    String
  balance         Int       @default(0)
  isEmailVerified Boolean   @default(false)
  isSmsVerified   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  employees     Employee[]
  attributions  Attribution[]  @relation("SenderAttributions")
  refreshTokens RefreshToken[]
}

model Employee {
  id              String    @id @default(uuid()) @db.Uuid
  firstName       String
  lastName        String
  email           String    @unique
  passwordHash    String
  balance         Int       @default(0)
  isEmailVerified Boolean   @default(false)
  isSmsVerified   Boolean   @default(false)
  invitationCode  String?
  managerId       String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  manager       Manager       @relation(fields: [managerId], references: [id])
  attributions  Attribution[] @relation("RecipientAttributions")
  redemptions   Redemption[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id           String   @id @default(uuid()) @db.Uuid
  tokenHash    String   @unique
  role         Role
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  replacedById String?  @db.Uuid
  createdAt    DateTime @default(now())

  managerId  String? @db.Uuid
  employeeId String? @db.Uuid
  adminId    String? @db.Uuid

  manager  Manager?  @relation(fields: [managerId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
  admin    Admin?    @relation(fields: [adminId], references: [id])
}

model Attribution {
  id         String   @id @default(uuid()) @db.Uuid
  amount     Int
  reason     String
  managerId  String   @db.Uuid
  employeeId String   @db.Uuid
  createdAt  DateTime @default(now())

  manager  Manager  @relation("SenderAttributions", fields: [managerId], references: [id])
  employee Employee @relation("RecipientAttributions", fields: [employeeId], references: [id])
}

model PartnerOffer {
  id          String   @id @default(uuid()) @db.Uuid
  partnerName String
  cost        Int
  valueEuros  Decimal  @db.Decimal(10, 2)
  category    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  promoCodes PromoCode[]
}

model PromoCode {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  offerId   String    @db.Uuid
  createdAt DateTime  @default(now())

  offer      PartnerOffer @relation(fields: [offerId], references: [id])
  redemption Redemption?
}

model Redemption {
  id          String   @id @default(uuid()) @db.Uuid
  amount      Int
  employeeId  String   @db.Uuid
  promoCodeId String   @unique @db.Uuid
  createdAt   DateTime @default(now())

  employee  Employee  @relation(fields: [employeeId], references: [id])
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}
