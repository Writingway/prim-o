# ─── Base de données ─────────────────────────────────────────────
DATABASE_URL="postgresql://primo:primo@localhost:5432/primo_db"

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_minimum_32_characters_long"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="CHANGE_ME_minimum_32_characters_long_different"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ─── Serveur ─────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
CLIENT_URL=http://localhost:5173

# ─── Rate limiting ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ─── SMS (à configurer) ──────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── Email (à configurer) ────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
